{
  "name": "@testforge/ai-engine",
  "version": "0.1.0",
  "description": "AI engine for TestForge — all AI-powered features",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers/index.d.ts",
      "import": "./dist/providers/index.js"
    },
    "./test-generator": {
      "types": "./dist/test-generator/index.d.ts",
      "import": "./dist/test-generator/index.js"
    },
    "./self-healer": {
      "types": "./dist/self-healer/index.d.ts",
      "import": "./dist/self-healer/index.js"
    },
    "./failure-analyzer": {
      "types": "./dist/failure-analyzer/index.d.ts",
      "import": "./dist/failure-analyzer/index.js"
    },
    "./intent-engine": {
      "types": "./dist/intent-engine/index.d.ts",
      "import": "./dist/intent-engine/index.js"
    },
    "./autonomous-agent": {
      "types": "./dist/autonomous-agent/index.d.ts",
      "import": "./dist/autonomous-agent/index.js"
    },
    "./visual-dna": {
      "types": "./dist/visual-dna/index.d.ts",
      "import": "./dist/visual-dna/index.js"
    },
    "./accessibility": {
      "types": "./dist/accessibility/index.d.ts",
      "import": "./dist/accessibility/index.js"
    },
    "./data-generator": {
      "types": "./dist/data-generator/index.d.ts",
      "import": "./dist/data-generator/index.js"
    },
    "./compliance": {
      "types": "./dist/compliance/index.d.ts",
      "import": "./dist/compliance/index.js"
    },
    "./d365-generator": {
      "types": "./dist/d365-generator/index.d.ts",
      "import": "./dist/d365-generator/index.js"
    },
    "./d365-healer": {
      "types": "./dist/d365-healer/index.d.ts",
      "import": "./dist/d365-healer/index.js"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "dev": "tsup src/index.ts --format esm --dts --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@testforge/core": "workspace:*",
    "@anthropic-ai/sdk": "^0.32.0",
    "ollama": "^0.5.9",
    "openai": "^4.73.0",
    "zod": "^3.23.8",
    "zod-to-json-schema": "^3.23.5",
    "debug": "^4.3.7",
    "axios": "^1.7.7",
    "axe-core": "^4.10.2",
    "pixelmatch": "^6.0.3",
    "pngjs": "^7.0.0",
    "@azure/msal-node": "^2.16.0"
  },
  "devDependencies": {
    "@types/debug": "^4.1.12",
    "@types/node": "^22.10.0",
    "tsup": "^8.3.5",
    "typescript": "^5.7.0",
    "vitest": "^2.1.8",
    "eslint": "^9.16.0"
  }
}
