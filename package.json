{
  "name": "testforge-ai",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source AI-powered test automation platform competing with Katalon + BrowserStack",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "test": "turbo run test",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean && rm -rf node_modules",
    "api:dev": "turbo run dev --filter=@testforge/api",
    "api:start": "node apps/api/dist/server.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@types/pngjs": "^6.0.5",
    "eslint": "^9.16.0",
    "turbo": "^2.3.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.17.0",
    "vitest": "^2.1.8"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "packageManager": "bun@1.1.38"
}
