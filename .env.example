# ============================================================================
# TestForge AI — Environment Variables
# ============================================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env to version control.
# ============================================================================

# ── AI Providers ─────────────────────────────────────────────────────────────
# At least one provider is required for AI-powered features.

# Anthropic Claude API key (cloud provider)
# Get yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=

# Ollama server URL (local/self-hosted provider)
# Default: http://localhost:11434
OLLAMA_BASE_URL=http://localhost:11434

# ── Database ─────────────────────────────────────────────────────────────────
# PostgreSQL connection string (used by Docker Compose and API server)
DATABASE_URL=postgresql://testforge:testforge@localhost:5432/testforge

# ── Redis / BullMQ ───────────────────────────────────────────────────────────
# Redis connection string for BullMQ job queues
REDIS_URL=redis://localhost:6379

# ── Authentication ───────────────────────────────────────────────────────────
# JWT secret for API authentication (CHANGE THIS in production!)
JWT_SECRET=change-me-in-production-use-a-long-random-string

# ── License ──────────────────────────────────────────────────────────────────
# Enterprise license key for EE features (compliance, device-cloud, etc.)
# Leave empty for Community Edition (CE)
TESTFORGE_LICENSE_KEY=

# ── Browserless (Docker) ────────────────────────────────────────────────────
# Token for the self-hosted Browserless Chromium grid
BROWSERLESS_TOKEN=testforge

# ── Optional: Notifications ──────────────────────────────────────────────────
# Slack webhook URL for test run notifications
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Microsoft Teams webhook URL
# TEAMS_WEBHOOK_URL=https://outlook.office.com/webhook/...

# ── Optional: Integrations ──────────────────────────────────────────────────
# GitHub repository for automatic PR creation
# GITHUB_REPO=your-org/your-repo

# Jira project key for automatic bug creation
# JIRA_PROJECT_KEY=TF

# ── Optional: Ollama Models ─────────────────────────────────────────────────
# Override default models used by Ollama provider
# OLLAMA_MODEL=llama3.1

# ── Optional: API Server ────────────────────────────────────────────────────
# PORT=3000
# HOST=0.0.0.0
# NODE_ENV=development
# LOG_LEVEL=info
